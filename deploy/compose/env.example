# Copy to .env in this directory (same folder as docker-compose.yml):
#   cp env.example .env
# Edit POSTGRES_PASSWORD at minimum before any shared/staging use.

POSTGRES_USER=openforge
POSTGRES_PASSWORD=openforge_dev_change_me
POSTGRES_DB=openforge

# Used by apps on the host (SvelteKit, workers) to reach Compose services.
# Default ports match docker-compose.yml published ports.
DATABASE_URL=postgresql://openforge:openforge_dev_change_me@localhost:5432/openforge
REDIS_URL=redis://localhost:6379

# Optional: if 5432 / 6379 are already taken on the host, set custom ports here and
# update DATABASE_URL / REDIS_URL above to the same host ports (Compose maps host:container).
# POSTGRES_PORT=5433
# REDIS_PORT=6380
# DATABASE_URL=postgresql://openforge:openforge_dev_change_me@localhost:5433/openforge
# REDIS_URL=redis://localhost:6380
